# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── Frontend (Next.js public — needed for Google OAuth via Supabase Auth) ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://talengineer.us,https://www.talengineer.us

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-admin-password

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=TalEngineer <hello@talengineer.us>

# ── AI ────────────────────────────────────────────────────────────────────────
# 注意：代码读取的变量名是 GEMINI_API_KEY（src/services/aiService.js），此前模板误写为 GOOGLE_API_KEY
GEMINI_API_KEY=your-gemini-api-key

# ── Business knobs（可选，均有安全默认值）─────────────────────────────────────
# 平台抽佣比例，[0,1) 小数，默认 0.15（路径 A 溢价时可调 0.20-0.25）
PLATFORM_FEE_PCT=0.15
# 撮合推荐池的入网硬门槛（verified_score 下限，0-100 整数）；0=关闭（默认）。
# 等池子筛选分覆盖率上来后（见 /admin Analytics 的 Scored Talents 指标）再拧开。
MIN_POOL_VERIFIED_SCORE=0
# SSR 回环调用本机 API 的地址（默认 http://127.0.0.1:$PORT，一般无需设置）
# INTERNAL_API_BASE=http://127.0.0.1:4000

# ── Monitoring ───────────────────────────────────────────────────────────────
# Get DSN from sentry.io → New Project → Node.js
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
DOMAIN=https://talengineer.us

# ── Frontend public site URL (used for OAuth redirects) ───────────────────────
NEXT_PUBLIC_SITE_URL=https://talengineer.us
