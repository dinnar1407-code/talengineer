# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── Frontend (Next.js public — needed for Google OAuth via Supabase Auth) ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://talengineer.us,https://www.talengineer.us

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-admin-password

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=TalEngineer <hello@talengineer.us>

# ── AI ────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key

# ── Monitoring ───────────────────────────────────────────────────────────────
# Get DSN from sentry.io → New Project → Node.js
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
DOMAIN=https://talengineer.us

# ── Frontend public site URL (used for OAuth redirects) ───────────────────────
NEXT_PUBLIC_SITE_URL=https://talengineer.us
